# Supabase (Cloud) — DO NOT COMMIT real values
SUPABASE_URL=https://mqgnvsqudbbkaymeqzzh.supabase.co
# Server-side only key (bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=your-service-role-key
# Public client key used by the UI login flow.
SUPABASE_ANON_KEY=your-anon-key
# Supabase JWT signing secret (Settings -> API -> JWT Secret) used to verify tokens.
SUPABASE_JWT_SECRET=your-jwt-secret

# App
APP_NAME=Tata Dashboard
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:8080
